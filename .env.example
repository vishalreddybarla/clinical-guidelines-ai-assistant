# OpenAI API Key - required for embeddings and GPT models
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Anthropic API Key - required to compare Claude models
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Cohere API Key - optional, used for reranking (free tier available)
# Get yours at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-key-here

# NCBI API Key - optional, increases PubMed rate limits
# Get one at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=
